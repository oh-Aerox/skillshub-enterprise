# Database
DATABASE_URL=postgresql://skillshub:skillshub_password@localhost:5432/skillshub

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=skillshub-files

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3000
GIN_MODE=debug

# Scanner Service
SCANNER_SERVICE_URL=http://localhost:8000

# Scan Configuration
SCAN_SANDBOX_TIMEOUT=120000
SCAN_MAX_CONCURRENT=5
AUTO_APPROVE_MAX_SCORE=30

# OAuth/OIDC (optional)
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Notification
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=
SLACK_WEBHOOK_URL=

# GitHub API (for sourcing)
GITHUB_TOKEN=
